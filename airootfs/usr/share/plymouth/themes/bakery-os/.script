
bakery_image = Image("bakery-os-logo.png"); 
bakery_sprite = Sprite();

bakery_sprite.SetImage(bakery_image);
bakery_sprite.SetX(Window.GetX() + (Window.GetWidth() / 2 - bakery_image.GetWidth() / 2));

bakery_sprite.SetY(Window.GetHeight() - bakery_image.GetHeight() - 100);

bakery_sprite.SetOpacity(1);
